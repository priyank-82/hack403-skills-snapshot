# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8000

# Authentication Method: 'cognito' or 'accessToken'
REACT_APP_AUTH_METHOD=cognito

# AWS Cognito Configuration (if using Cognito)
REACT_APP_COGNITO_USER_POOL_ID=your-user-pool-id
REACT_APP_COGNITO_CLIENT_ID=your-client-id
REACT_APP_COGNITO_REGION=us-east-1

# Access Token Configuration (if using access token)
REACT_APP_ACCESS_TOKEN_ENDPOINT=/auth/login
REACT_APP_REFRESH_TOKEN_ENDPOINT=/auth/refresh

# Emsi API (if using)
REACT_APP_EMSI_API_KEY=your-emsi-api-key
REACT_APP_EMSI_BASE_URL=https://emsiservices.com/
